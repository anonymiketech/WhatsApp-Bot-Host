# ═══════════════════════════════════════════
# ANONYMIKETECH — Environment Variables
# Copy this file to .env and fill in values
# ═══════════════════════════════════════════

# ── Server ─────────────────────────────────
PORT=3000
SERVE_STATIC=true
NODE_ENV=production

# ── Database ────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/anonymiketech

# ── Authentication ──────────────────────────
# GitHub OAuth App credentials
# Create at: https://github.com/settings/applications/new
# Callback URL: https://yourdomain.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth App credentials
# Create at: https://console.cloud.google.com/
# Callback URL: https://yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Admin ───────────────────────────────────
# Comma-separated emails that get admin access
ADMIN_EMAILS=admin@yourdomain.com

# ── Pterodactyl Panel ───────────────────────
PTERODACTYL_URL=https://your-panel.com
PTERODACTYL_API_KEY=ptla_...

# ── Email (Resend) ──────────────────────────
RESEND_API_KEY=re_...

# ── Payments (Payflow / M-Pesa) ─────────────
PAYFLOW_ACCOUNT_ID=
PAYFLOW_API_KEY=
PAYFLOW_API_SECRET=

# ── Optional ────────────────────────────────
LOG_LEVEL=info
